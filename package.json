{
  "name": "easy-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenAI-compatible gateway for OpenRouter that auto-selects healthy models, prefers free ones, falls back when they fail, and keeps client integrations stable.",
  "keywords": [
    "openrouter",
    "openai-compatible",
    "llm-gateway",
    "ai-gateway",
    "multimodal",
    "fastify"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YooHoeh/easy-openrouter-api.git"
  },
  "bugs": {
    "url": "https://github.com/YooHoeh/easy-openrouter-api/issues"
  },
  "homepage": "https://github.com/YooHoeh/easy-openrouter-api#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node build/server.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fastify": "^5.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
