# 服务监听地址，默认 0.0.0.0
HOST=0.0.0.0

# 服务端口，默认 3000
PORT=3000

# 日志级别：fatal / error / warn / info / debug / trace / silent
LOG_LEVEL=info

# 是否默认附带调试路由信息
ENABLE_DEBUG_ROUTE_METADATA=false

# 是否允许从免费模型降级到付费模型
# 默认关闭。只有你明确接受产生费用时再改成 true
ALLOW_PAID_FALLBACK=false

# 当你显式指定某个模型时，如果上游运行时返回可重试错误，
# 是否允许自动降级到预计算的安全候选链
ENABLE_EXPLICIT_MODEL_RUNTIME_FALLBACK=false

# 可选。设置后，请求遥测会以 NDJSON 方式追加写入这个文件
# 示例：.logs/requests.ndjson
TELEMETRY_REQUEST_LOG_PATH=

# 可选但很重要。
# 不填也能启动服务，但真实调用 OpenRouter 时会失败。
# 不要把真实 key 提交进仓库。
OPENROUTER_API_KEY=
